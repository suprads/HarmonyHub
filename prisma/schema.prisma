model History {
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  trackSource   TrackSource @relation(fields: [trackSourceId], references: [id])
  trackSourceId BigInt
  /// When the track was played by the user
  playedAt      DateTime?
  createdAt     DateTime    @default(now())

  @@id([userId, trackSourceId])
}

/// Data needed for a user to receive push notifications.
model PushSubscription {
  id             BigInt    @id @default(autoincrement())
  session        Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId      String    @unique
  endpoint       String
  expirationTime DateTime?
  auth           String
  p256dh         String
}

model Settings {
  id                   BigInt                @id @default(autoincrement())
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String                @unique
  notificationSettings NotificationSettings?
}

model NotificationSettings {
  id             BigInt   @id @default(autoincrement())
  settings       Settings @relation(fields: [settingsId], references: [id])
  settingsId     BigInt   @unique
  enabled        Boolean  @default(true)
  friendRequests Boolean  @default(true)
}

model Notification {
  id        BigInt           @id @default(autoincrement())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  read      Boolean          @default(false)
  type      NotificationType
  /// ID of related data from another table. Table to get from should be based on the notification type. Should separate composite IDs with a underscore.
  infoId    String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([type, infoId])
}

enum Provider {
  SPOTIFY
  YTMUSIC
  // APPLE
  // SOUNDCLOUD
}

enum NotificationType {
  FRIEND_REQUEST
}
